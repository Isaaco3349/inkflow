# ─── Anthropic / Claude ───────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── ZeroDev (Account Abstraction) ───────────────────────────────
ZERODEV_PROJECT_ID=your_zerodev_project_id_here
ZERODEV_BUNDLER_RPC=https://rpc.zerodev.app/api/v2/bundler/your_project_id
ZERODEV_PAYMASTER_RPC=https://rpc.zerodev.app/api/v2/paymaster/your_project_id

# ─── Alchemy ──────────────────────────────────────────────────────
ALCHEMY_API_KEY=your_alchemy_api_key_here

# ─── Inkonchain / RPC ─────────────────────────────────────────────
NEXT_PUBLIC_INK_RPC_URL=https://rpc-gel.inkonchain.com
NEXT_PUBLIC_INK_CHAIN_ID=57073

# ─── Paystack ─────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key_here
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key_here

# ─── Flutterwave ──────────────────────────────────────────────────
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-your_flutterwave_secret_key_here
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-your_flutterwave_public_key_here
FLUTTERWAVE_ENCRYPTION_KEY=your_flutterwave_encryption_key_here

# ─── App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Inkflow
