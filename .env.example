# ─────────────────────────────────────────────
# Inkflow — Environment Variables
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to git
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Inkflow

# ── Inkonchain / RPC ─────────────────────────
# Get from: https://docs.inkonchain.com/tools/rpc
NEXT_PUBLIC_INK_RPC_URL=https://rpc-gel.inkonchain.com
NEXT_PUBLIC_INK_CHAIN_ID=57073

# ── ZeroDev (Account Abstraction) ────────────
# Get from: https://dashboard.zerodev.app
NEXT_PUBLIC_ZERODEV_PROJECT_ID=
ZERODEV_API_KEY=

# ── Claude API (AI Intent Parsing) ───────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Paystack (Nigeria payments) ───────────────
# Get from: https://dashboard.paystack.com/#/settings/developers
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_
PAYSTACK_SECRET_KEY=sk_test_
PAYSTACK_WEBHOOK_SECRET=

# ── Flutterwave (Pan-Africa payments) ─────────
# Get from: https://developer.flutterwave.com/docs
NEXT_PUBLIC_FLW_PUBLIC_KEY=FLWPUBK_TEST-
FLW_SECRET_KEY=FLWSECK_TEST-
FLW_ENCRYPTION_KEY=
FLW_WEBHOOK_SECRET=

# ── Wallet / Auth ─────────────────────────────
# Used for embedded wallet session signing
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ── Misc ──────────────────────────────────────
NODE_ENV=development
# ERC-8004 Agent Identity
AGENT_PRIVATE_KEY=             # Dedicated wallet for the Inkflow agent (NOT user wallet)
ERC8004_AGENT_ID=              # Assigned after registerAgent() is called once